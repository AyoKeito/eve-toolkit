CONTACT_EMAIL=dev@example.com
APP_URL=http://localhost:3004
ADMIN_TOKEN=change-me

# Optional runtime settings
PORT=3004
HOST=0.0.0.0
TRUST_PROXY=0
API_READ_RATE_LIMIT_MAX=180
DB_PATH=./data/lp.db
LOG_DIR=./logs
LOG_LEVEL=info
SDE_JSONL_URL=https://developers.eveonline.com/static-data/eve-online-static-data-latest-jsonl.zip
BACKUP_RETENTION_DAYS=30
ESI_CACHE_MAX_ROWS=20000
ESI_REQUEST_TIMEOUT_MS=30000
# Brotli quality (0-11) for precompressed API response bodies. Default 6: quality 11
# is ~100x slower for ~19% smaller output, and these bodies are edge-cached, so 6 is
# the sweet spot. Read once at startup — change needs a restart.
BROTLI_QUALITY=6

# Lowsec faction-warfare killmail ingestion (daily EVE-Ref archive -> trending fits).
KILLMAILS_ENABLED=true
# CSV of warzone region IDs; blank = the 9 FW warzone regions. Lowsec filter is applied on top.
KILLMAILS_WARZONE_REGIONS=
# Days back (ending yesterday UTC) to pull per run. 1 = yesterday; raise to warm up / catch up.
KILLMAILS_BACKFILL_DAYS=1

# Public-contracts scan. PRICE regions feed the BPC/contract-only price rollup (default The Forge,
# ~98% type coverage). SATURATION regions add fitted-ship SUPPLY for the /fits/ competition check
# (default the 9 FW warzone regions) WITHOUT polluting prices. The fetcher scans the union.
# CONTRACT_PRICE_REGIONS=        # CSV; blank = The Forge (10000002). Legacy CONTRACT_REGIONS still honored.
# CONTRACT_SATURATION_REGIONS=   # CSV; blank = the 9 warzone regions.
# false keeps the scan price-regions-only (skips the warzone backfill):
CONTRACT_SATURATION_ENABLED=true

# Optional Cloudflare cache purge integration. Leave blank in local dev.
# CF_API_TOKEN is the ALWAYS-ON runtime credential; it only needs Zone:Cache Purge:Edit
# (compute-time + deploy purges). Do NOT give it ruleset edit.
CF_ZONE_ID=
CF_API_TOKEN=
# Operator-only token with ruleset edit (Zone:Cache Rules), used by scripts/cf-ruleset.mjs the
# 1-2 times you maintain the Cache Rules. Set it in your SHELL when running cf:ruleset:* — keep
# it OUT of this file / the compose env_file so the elevated scope never enters the 24/7 container.
# CF_RULESET_API_TOKEN=
